<mxfile host="app.diagrams.net">
  <diagram name="BeaverAgent Enhanced Loop" id="beaver-agent-enhanced">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="BeaverAgent 增强推理流程 (think_mode + self_critique)" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacingTop=5;spacingBottom=5;fontColor=#1A1A2E;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="600" height="30" as="geometry"/>
        </mxCell>

        <!-- User Input -->
        <mxCell id="user_input" value="用户输入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#4A90E2;fontColor=#1A1A2E;fontSize=12;align=center;verticalAlign=middle;spacingTop=3;spacingBottom=3;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="500" y="70" width="120" height="40" as="geometry"/>
        </mxCell>

        <!-- Arrow: User -> Parse Intent -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="user_input" target="parse_intent">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 1: Parse Intent -->
        <mxCell id="parse_intent" value="Step 1&#xa;解析 Intent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4E6F1;strokeColor=#2E86AB;fontColor=#1A1A2E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="130" width="100" height="45" as="geometry"/>
        </mxCell>

        <!-- Arrow: Parse -> Think (conditional) -->
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="parse_intent" target="think_mode">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Think Mode (conditional) -->
        <mxCell id="think_mode" value="⚡ Step 2a (if think_mode)&#xa;Chain-of-Thought 推理&#xa;&#xa;❝ 先让 LLM 输出思路&#xa;再执行工具 ❞" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#E6A817;fontColor=#856404;fontSize=11;align=center;verticalAlign=middle;dashed=0;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="460" y="200" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrow: Think -> Plan -->
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="think_mode" target="plan_tasks">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: Parse -> Plan (skip think) -->
        <mxCell id="a_skip_think" value="跳过&#xa;(think_mode=false)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="parse_intent" target="plan_tasks">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="360" y="157"/>
              <mxPoint x="360" y="280"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 2/3: Plan Tasks -->
        <mxCell id="plan_tasks" value="Step 2/3&#xa;规划任务 (TaskPlanner)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4E6F1;strokeColor=#2E86AB;fontColor=#1A1A2E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="290" width="100" height="45" as="geometry"/>
        </mxCell>

        <!-- Arrow: Plan -> Execute -->
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="plan_tasks" target="execute_tools">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 3: Execute Tools -->
        <mxCell id="execute_tools" value="Step 4&#xa;执行工具 (ToolRouter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4E6F1;strokeColor=#2E86AB;fontColor=#1A1A2E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="360" width="100" height="45" as="geometry"/>
        </mxCell>

        <!-- Loop for multiple tools -->
        <mxCell id="loop_tools" value="for each task in tasks" style="text;html=1;fontSize=10;fontColor=#666666;align=center;verticalAlign=middle;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="610" y="365" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="a_loop" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4CAF50;strokeWidth=1;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="execute_tools" target="execute_tools">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="650" y="382"/>
              <mxPoint x="650" y="480"/>
              <mxPoint x="580" y="480"/>
              <mxPoint x="580" y="420"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Arrow: Execute -> Generate Response -->
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="execute_tools" target="generate_response">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="530" y="405"/>
              <mxPoint x="530" y="445"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 5: Generate Response -->
        <mxCell id="generate_response" value="Step 5&#xa;生成响应 (_generate_response)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4E6F1;strokeColor=#2E86AB;fontColor=#1A1A2E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="460" width="100" height="45" as="geometry"/>
        </mxCell>

        <!-- Self-Critique (conditional) -->
        <mxCell id="self_critique" value="🔍 Step 6 (if self_critique)&#xa;Self-Critique 自我评审&#xa;&#xa;❝ 让 LLM 评审输出质量&#xa;有缺陷则重新生成 ❞" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;fontColor=#1B5E20;fontSize=11;align=center;verticalAlign=middle;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="460" y="530" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrow: Generate -> Critique -->
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="generate_response" target="self_critique">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Re-generate loop -->
        <mxCell id="a_retry" value="质量不达标&#xa;重新生成" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E53935;strokeWidth=1;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="self_critique" target="generate_response">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="560"/>
              <mxPoint x="600" y="482"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Skip critique path -->
        <mxCell id="a_skip_crit" value="跳过&#xa;(self_critique=false)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="generate_response" target="final_output">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="482"/>
              <mxPoint x="700" y="610"/>
              <mxPoint x="530" y="610"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Final Output -->
        <mxCell id="final_output" value="✅ 最终输出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontColor=#1B5E20;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="480" y="620" width="100" height="40" as="geometry"/>
        </mxCell>

        <!-- Arrow: Critique -> Final -->
        <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1.5;endArrow=classic;endFill=1;" edge="1" parent="1" source="self_critique" target="final_output">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Store Memory -->
        <mxCell id="store_memory" value="存储记忆&#xa;(_extract_and_store_memory)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontColor=#4A148C;fontSize=10;align=center;verticalAlign=middle;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="620" y="530" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="a_mem" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7B1FA2;strokeWidth=1;endArrow=classic;endFill=1;" edge="1" parent="1" source="self_critique" target="store_memory">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a_mem2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7B1FA2;strokeWidth=1;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="store_memory" target="final_output">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Config Box -->
        <mxCell id="config_box" value="AppConfig&#xa;├── think_mode: bool&#xa;└── self_critique: bool" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;fontColor=#424242;fontSize=10;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;spacingRight=8;spacingBottom=5;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="800" y="130" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="a_config" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#BDBDBD;strokeWidth=1;endArrow=none;endFill=0;dashed=1;" edge="1" parent="1" source="config_box" target="think_mode">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a_config2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#BDBDBD;strokeWidth=1;endArrow=none;endFill=0;dashed=1;" edge="1" parent="1" source="config_box" target="self_critique">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="800" y="185"/>
              <mxPoint x="800" y="560"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="图例" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#1A1A2E;align=left;verticalAlign=top;spacingTop=2;spacingBottom=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="50" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="标准流程" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4E6F1;strokeColor=#2E86AB;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="95" width="70" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="think_mode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#E6A817;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="122" width="70" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="self_critique" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="149" width="70" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="leg4" value="条件跳过" style="text;html=1;strokeColor=#999999;strokeWidth=1;fontSize=10;fontColor=#999999;align=center;verticalAlign=middle;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="176" width="70" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="leg5" value="重试循环" style="text;html=1;strokeColor=#E53935;strokeWidth=1;fontSize=10;fontColor=#E53935;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="199" width="70" height="18" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
